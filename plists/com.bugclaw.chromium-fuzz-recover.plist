<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bugclaw.chromium-fuzz-recover</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/bugclaw/.openclaw/workspace/chromium-vrp &amp;&amp; ./fuzz/recover_main_fuzzing_stack.sh &gt;&gt; ./fuzz/logs/launchd_recover.out.log 2&gt;&amp;1</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/bugclaw</string>
        <key>MAX_TOTAL_TIME</key>
        <string>172800</string>
    </dict>
    <key>WorkingDirectory</key>
    <string>/Users/bugclaw/.openclaw/workspace/chromium-vrp</string>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>900</integer>
    <key>StandardOutPath</key>
    <string>/Users/bugclaw/.openclaw/workspace/chromium-vrp/fuzz/logs/launchd_recover.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/bugclaw/.openclaw/workspace/chromium-vrp/fuzz/logs/launchd_recover.stderr.log</string>
</dict>
</plist>
