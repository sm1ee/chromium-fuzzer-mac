WORKER_ROOT="/Users/smlee/chromium-worker"
SRC_ROOT="$WORKER_ROOT/src"
DEPOT_TOOLS="/Users/smlee/depot_tools"
XCODE_APP="/Users/smlee/Applications/Xcode.app"
OUT_DIR="$SRC_ROOT/out/fuzz-asan-mac-arm64"
PRIMARY_TARGET="media_h264_decoder_fuzzer"
REPO_ROOT="/Users/smlee/chromium-fuzzer-mac"
OPS_ROOT="/Users/smlee/chromium-worker-ops"
DATA_ROOT="/Users/smlee/chromium-fuzz-data"
EXPECTED_HEAD_FILE="$DATA_ROOT/state/expected_head"
MAX_CHECKOUT_AGE_SECS="604800"
MAX_BINARY_AGE_SECS="604800"
NINJA_JOBS="6"

export WORKER_ROOT SRC_ROOT DEPOT_TOOLS XCODE_APP OUT_DIR PRIMARY_TARGET REPO_ROOT OPS_ROOT DATA_ROOT
export EXPECTED_HEAD_FILE MAX_CHECKOUT_AGE_SECS MAX_BINARY_AGE_SECS NINJA_JOBS
export DEVELOPER_DIR="$XCODE_APP/Contents/Developer"
export PATH="$DEPOT_TOOLS:/usr/bin:/bin:/usr/sbin:/sbin"
export PYTHONNOUSERSITE=1
